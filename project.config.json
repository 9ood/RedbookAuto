{
  "id": "redbook-auto",
  "name": "小红书自动发布",
  "category": "内容类",
  "type": "queue-worker",
  "status": "draft",
  "summary": "从待发布队列里取一条内容，自动调用小红书发布工具，并归档结果。",
  "description": "这是一个队列发布项目。现在已经接入 dashboard，可以做环境检查、真实运行和停止。第一次使用前，如果还没登录小红书，会自动拉起登录流程。",
  "path": "E:/Project/codex/RedbookAuto",
  "entry": "",
  "health": "",
  "integration": "project-config",
  "control": {
    "enabled": true,
    "type": "queue-worker",
    "actions": ["test", "run", "stop"],
    "testCommand": {
      "command": "powershell",
      "args": ["-NoProfile", "-NonInteractive", "-ExecutionPolicy", "Bypass", "-File", "scripts/test.ps1"]
    },
    "runCommand": {
      "command": "powershell",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/run.ps1"]
    },
    "stopCommand": {
      "command": "powershell",
      "args": ["-NoProfile", "-NonInteractive", "-ExecutionPolicy", "Bypass", "-File", "scripts/stop.ps1"]
    },
    "processMatch": {
      "name": "python.exe",
      "commandLinePattern": "*RedbookAuto*publisher\\run_once.py*"
    }
  },
  "paths": {
    "logs": "logs",
    "queue": "queue",
    "config": "config.json"
  },
  "timeline": [
    {
      "time": "今天",
      "title": "接入真实控制层",
      "note": "dashboard 现在可以检查环境、尝试发布和停止当前运行。"
    }
  ]
}
