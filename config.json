{
  "queue_dir": "queue",
  "log_dir": "logs",
  "status": {
    "enabled": true,
    "command": ["node", "xhs-mcp-fix/dist/xhs-mcp.js", "status", "--compact"]
  },
  "publish": {
    "mode": "command",
    "command": [
      "node",
      "xhs-mcp-fix/dist/xhs-mcp.js",
      "publish",
      "--type",
      "image",
      "--title",
      "{title}",
      "--content",
      "{content}",
      "-m",
      "{images_csv}",
      "--tags={tags?}"
    ]
  }
}
